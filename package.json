{
  "name": "package-ninja",
  "version": "1.0.0",
  "description": "A polished local package registry session wrapper for npm, pnpm, and yarn.",
  "type": "module",
  "bin": {
    "package-ninja": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:go-worker": "node scripts/build-go-worker.mjs",
    "dev": "tsx src/cli.ts",
    "test": "npm run build && node dist/selftest.js"
  },
  "keywords": [
    "package-ninja",
    "registry",
    "npm",
    "pnpm",
    "yarn",
    "local-dev"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cli-spinners": "^3.4.0",
    "package-ninja-registry-runtime": "npm:verdaccio@^6.1.6"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
